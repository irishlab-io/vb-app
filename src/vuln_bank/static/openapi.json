    "/api/v{version}/forgot-password": {
      "post": {
        "description": "Generate reset PIN. v1/v2 issue 3-digit PINs (v1 exposes PIN, v2 hides it); v3 issues 4-digit PINs without exposing the PIN.",
        "parameters": [
          {
            "description": "API version (1: old endpoint, 2: reduced exposure, 3: 4-digit PIN default)",
            "in": "path",
            "name": "version",
            "required": true,
            "schema": {
              "default": 3,
              "enum": [
                1,
                2,
                3
              ],
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "username": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "debug_info": {
                      "description": "v1: Contains extensive sensitive information including PIN. v2: Less sensitive information, PIN not exposed.",
                      "type": "object"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Reset PIN generated"
          },
          "404": {
            "description": "User not found"
          }
        },
        "summary": "Request password reset (versioned)",
        "tags": [
          "authentication"
        ]
      }
    },
    "/api/v{version}/reset-password": {
      "post": {
        "description": "Reset password with PIN. v1/v2 expect 3-digit PINs, v3 expects 4-digit PINs by default.",
        "parameters": [
          {
            "description": "API version (1: full data exposure, 2: reduced data exposure, 3: 4-digit PIN default)",
            "in": "path",
            "name": "version",
            "required": true,
            "schema": {
              "default": 3,
              "enum": [
                1,
                2,
                3
              ],
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "new_password": {
                    "type": "string"
                  },
                  "reset_pin": {
                    "description": "3 digits for v1/v2, 4 digits for v3 (default)",
                    "pattern": "^\\d{3,4}$",
                    "type": "string"
                  },
                  "username": {
                    "type": "string"
                  }
                },
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "properties": {
                    "debug_info": {
                      "description": "v1: Contains extensive debug information including used PIN. v2: Not present.",
                      "type": "object"
                    },
                    "message": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Password reset successful"
          },
          "400": {
            "description": "Invalid reset PIN"
          }
        },
        "summary": "Reset password using PIN (versioned)",
        "tags": [
          "authentication"
        ]
      }
